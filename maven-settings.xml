<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">
    <!--
      Project-level Maven settings:
      - use Aliyun public mirror for dependency and plugin resolution
      - keep mirror id "alimaven" for consistency
      - the local repository is provided via -Dmaven.repo.local or .mvn/maven.config
    -->
    <mirrors>
        <mirror>
            <id>alimaven</id>
            <mirrorOf>*</mirrorOf>
            <name>Aliyun Maven Public Mirror</name>
            <url>https://maven.aliyun.com/repository/public</url>
        </mirror>
    </mirrors>
</settings>
