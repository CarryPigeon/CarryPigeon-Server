<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0 https://maven.apache.org/xsd/assembly-2.1.0.xsd">
    <id>dist</id>
    <formats>
        <format>dir</format>  <!-- 同时支持zip格式 -->
        <format>zip</format>
    </formats>

    <dependencySets>
        <dependencySet>
            <outputDirectory>libs</outputDirectory>
            <useProjectArtifact>false</useProjectArtifact>
            <scope>runtime</scope>
            <unpack>false</unpack>
            <excludes>
                <exclude>CarryPigeon:application-starter</exclude>
            </excludes>
        </dependencySet>
    </dependencySets>

    <fileSets>
        <fileSet>
            <directory>${project.basedir}/../application-starter/target</directory>
            <outputDirectory>app</outputDirectory>
            <includes>
                <include>application-starter-*.jar</include>
            </includes>
            <excludes>
                <exclude>*-exec.jar</exclude>
                <exclude>*-exec.jar.original</exclude>
            </excludes>
        </fileSet>

        <fileSet>
            <directory>${project.basedir}/../application-starter/src/main/resources</directory>
            <outputDirectory>config</outputDirectory>
            <includes>
                <include>application.yaml</include>
            </includes>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/../infrastructure-basic/src/main/resources</directory>
            <outputDirectory>config</outputDirectory>
            <includes>
                <include>log4j2-spring.xml</include>
            </includes>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/bin</directory>
            <outputDirectory>bin</outputDirectory>
            <fileMode>0755</fileMode>
            <includes>
                <include>stop.sh</include>
                <include>stop.bat</include>
                <include>stop.ps1</include>
                <include>start-background.sh</include>
                <include>start-background.bat</include>
                <include>start-background.ps1</include>
                <include>start.sh</include>
                <include>start.bat</include>
                <include>start.ps1</include>
                <include>verify.sh</include>
                <include>verify.bat</include>
                <include>verify.ps1</include>
            </includes>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/service</directory>
            <outputDirectory>service</outputDirectory>
            <fileMode>0644</fileMode>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}</directory>
            <outputDirectory>.</outputDirectory>
            <includes>
                <include>README.md</include>
            </includes>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/..</directory>
            <outputDirectory>.</outputDirectory>
            <includes>
                <include>.env.example</include>
            </includes>
        </fileSet>
    </fileSets>
</assembly>
